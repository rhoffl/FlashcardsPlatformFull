
@model FlashcardsPlatformFull.Models.Deck
@{
  ViewData["Title"] = "Delete Deck";
}
<h2>Delete Deck</h2>
<div class="alert alert-danger">Are you sure you want to delete <strong>@Model.Name</strong> and all its cards?</div>
<form method="post">
  <button class="btn btn-danger">Delete</button>
  <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>
