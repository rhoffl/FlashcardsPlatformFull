
@model FlashcardsPlatformFull.Models.Flashcard
@{
  ViewData["Title"] = "Delete Card";
}
<h2>Delete Card</h2>
<div class="alert alert-danger">Are you sure you want to delete this card?</div>
<div class="card p-3">
  <div class="fw-semibold">@Model.Question</div>
  <div class="text-muted">@Model.Answer</div>
</div>
<form method="post" class="mt-3">
  <button class="btn btn-danger">Delete</button>
  <a class="btn btn-secondary" asp-action="Index" asp-route-deckId="@Model.DeckId">Cancel</a>
</form>
