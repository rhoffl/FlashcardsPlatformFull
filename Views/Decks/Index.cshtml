
@model IEnumerable<FlashcardsPlatformFull.Models.Deck>
@{
  ViewData["Title"] = "Decks";
}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Decks</h1>
  @if (User.IsInRole("Admin"))
  {
    <a class="btn btn-primary" asp-action="Create">Create Deck</a>
  }
</div>

<div class="row">
@foreach (var d in Model)
{
  <div class="col-md-6 col-lg-4 mb-3">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h5 class="card-title">@d.Name</h5>
        <p class="card-text text-muted">@d.Description</p>
        <p class="small text-muted mb-2">Cards: @d.Flashcards.Count</p>
        <div class="d-flex gap-2">
          <a class="btn btn-outline-primary btn-sm" asp-action="Details" asp-route-id="@d.Id">Open</a>
          @if (User.IsInRole("Admin"))
          {
            <a class="btn btn-outline-warning btn-sm" asp-action="Edit" asp-route-id="@d.Id">Edit</a>
            <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@d.Id">Delete</a>
          }
        </div>
      </div>
    </div>
  </div>
}
</div>
