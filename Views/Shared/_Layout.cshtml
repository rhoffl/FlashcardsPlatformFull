
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>@ViewData["Title"] - FlashcardsPlatformFull</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="~/css/site.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" asp-controller="Decks" asp-action="Index">Flashcards</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" asp-controller="Decks" asp-action="Index">Decks</a></li>
        <li class="nav-item"><a class="nav-link" asp-controller="Leaderboard" asp-action="Index">Leaderboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/swagger" target="_blank">API Docs</a></li>
      </ul>
      <div class="d-flex gap-2">
        <button id="dark-toggle" class="btn btn-sm btn-outline-light">Dark</button>
        @if (User?.Identity?.IsAuthenticated ?? false)
        {
          <span class="navbar-text text-light small me-2">Hello, @(User.Identity?.Name)</span>
          <form method="post" action="/Identity/Account/Logout">
            <button class="btn btn-sm btn-outline-warning">Logout</button>
          </form>
          @if (User.IsInRole("Admin"))
          {
            <a class="btn btn-sm btn-outline-info" asp-controller="Admin" asp-action="Index">Admin</a>
          }
        }
        else
        {
          <a class="btn btn-sm btn-outline-success" href="/Identity/Account/Login">Login</a>
          <a class="btn btn-sm btn-outline-secondary" href="/Identity/Account/Register">Register</a>
        }
      </div>
    </div>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Decks" asp-action="Index">Decks</a>
                    </li>
                </ul>

                <partial name="_LoginPartial" />
            </div>

  </div>
</nav>

<main class="container py-4">
  @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/darkmode.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
