<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - FlashcardsPlatformFull</title>
    <link rel="manifest" href="/manifest.webmanifest">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Decks" asp-action="Index">Flashcards</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="nav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Decks" asp-action="Index">Decks</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Leaderboard" asp-action="Index">Leaderboard</a></li>
                        <li class="nav-item"><a class="nav-link" href="/swagger" target="_blank">API Docs</a></li>
                    </ul>

                    <button id="dark-toggle" class="btn btn-sm btn-outline-light me-2">Dark</button>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>

        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Guest"))
        {
            <div class="alert alert-info text-center mb-0 rounded-0">
                You are signed in as a read-only guest. Editing, importing, deleting, and admin actions are disabled.
            </div>
        }

        <main class="container py-4">
            @RenderBody()
        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/darkmode.js"></script>
        <script>
            if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(() => {});
            }
        </script>
        @RenderSection("Scripts", required: false)
    </body>
</html>