@model FlashcardsPlatformFull.Controllers.AdminController.GenerateVm

@{
    ViewData["Title"] = "Generate Flashcards";
    var decks = (IEnumerable<FlashcardsPlatformFull.Models.Deck>)ViewData["Decks"]!;
}

<h2>Generate Flashcards</h2>
<p class="text-muted">Uses a stub generator unless OpenAI:ApiKey is set.</p>

@if (ViewData["Error"] != null)
{
    <div class="alert alert-danger">@ViewData["Error"]</div>
}

<form method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Deck</label>
        <select class="form-select" asp-for="DeckId">
            <option value="0">-- Select Deck --</option>
            @foreach (var deck in decks)
            {
                <option value="@deck.Id">@deck.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Topic</label>
        <input class="form-control"
               asp-for="Topic"
               placeholder="e.g. Project management basics" />
    </div>

    <div class="mb-3">
        <label class="form-label">Count (1-50)</label>
        <input class="form-control"
               asp-for="Count"
               type="number"
               min="1"
               max="50" />
    </div>

    <button class="btn btn-primary">Generate</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>