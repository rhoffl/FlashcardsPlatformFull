@model FlashcardsPlatformFull.Controllers.AdminController.AdminDashboardVm

@{
    ViewData["Title"] = "Admin";
}

<h2>Admin Dashboard</h2>

<div class="row mb-3">
    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <div class="text-muted small">Users</div>
            <div class="fs-4">@Model.TotalUsers</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <div class="text-muted small">Decks</div>
            <div class="fs-4">@Model.TotalDecks</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <div class="text-muted small">Cards</div>
            <div class="fs-4">@Model.TotalCards</div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <div class="text-muted small">Reviews</div>
            <div class="fs-4">@Model.TotalReviews</div>
        </div>
    </div>
</div>

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-primary" asp-action="Generate">Generate Flashcards</a>
</div>

<h4>Top Users</h4>

<table class="table table-sm">
    <thead>
        <tr>
            <th>User</th>
            <th>Points</th>
            <th>Reviews</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.TopUsers)
        {
            <tr>
                <td>@(user.User.DisplayName ?? user.User.UserName)</td>
                <td>@user.Points</td>
                <td>@user.TotalReviews</td>
            </tr>
        }
    </tbody>
</table>

<div class="alert alert-info">
    Default seeded admin:
    <strong>admin@local</strong> /
    <strong>Admin123!ChangeMe</strong>
</div>